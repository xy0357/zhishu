MYSQL_URL=mysql://zhishu:zhishu@127.0.0.1:3306/zhishu
REDIS_URL=redis://127.0.0.1:6379
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=
MINIO_ENDPOINT=http://127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=zhishu
OBJECT_STORAGE_DIR=data/object-storage

# 路线 B（无 Docker）建议：
# - MySQL 继续使用本机安装服务
# - REDIS_URL 可指向 Windows 兼容实现，例如 Memurai
# - QDRANT_URL 可指向外部 Qdrant 服务
# - 如使用 Qdrant Cloud，请通过环境变量提供 QDRANT_API_KEY，不要把密钥写入脚本或代码
# - 当前代码仍可只依赖 OBJECT_STORAGE_DIR，本地对象目录镜像可先替代真实 MinIO
